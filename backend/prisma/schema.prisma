generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Company {
  id          String   @id @default(uuid())
  name        String
  slug        String   @unique
  mission     String?
  settings    Json     @default("{}")
  telegramBotToken    String?  @map("telegram_bot_token")
  telegramWebhookUrl  String?  @map("telegram_webhook_url")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  users       User[]
  orgNodes    OrgNode[]
  goals       Goal[]
  tickets     Ticket[]
  budgets     Budget[]
  heartbeats  Heartbeat[]
  approvals   Approval[]
  auditLogs   AuditLog[]
  skills      Skill[]
  apiKeys     ApiKey[]

  @@map("companies")
}

model User {
  id            String   @id @default(uuid())
  email         String   @unique
  passwordHash  String   @map("password_hash")
  name          String?
  role          String   @default("admin")
  companyId     String   @map("company_id")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  company       Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  tickets       Ticket[]
  approvalsApproved Approval[] @relation("ApprovedBy")

  @@map("users")
}

model OrgNode {
  id          String   @id @default(uuid())
  companyId   String   @map("company_id")
  agentId     String?  @map("agent_id")
  title       String
  department  String?
  reportsToId String?  @map("reports_to_id")
  level       Int      @default(0)
  positionX   Float?   @map("position_x")
  positionY   Float?   @map("position_y")
  metadata    Json     @default("{}")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  company     Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  reportsTo   OrgNode?  @relation("OrgHierarchy", fields: [reportsToId], references: [id])
  children    OrgNode[] @relation("OrgHierarchy")
  goals       Goal[]
  tickets     Ticket[]
  budgets     Budget[]
  approvals   Approval[]

  @@map("org_nodes")
}

model Goal {
  id          String   @id @default(uuid())
  companyId   String   @map("company_id")
  parentId    String?  @map("parent_id")
  type        String
  title       String
  description String?
  status      String   @default("active")
  progress    Int      @default(0)
  assignedToId String? @map("assigned_to_id")
  dueDate     DateTime? @map("due_date")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  company     Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  parent      Goal?     @relation("GoalHierarchy", fields: [parentId], references: [id])
  children    Goal[]    @relation("GoalHierarchy")
  assignedTo  OrgNode?  @relation(fields: [assignedToId], references: [id])
  tickets     Ticket[]

  @@map("goals")
}

model Ticket {
  id          String   @id @default(uuid())
  companyId   String   @map("company_id")
  goalId      String?  @map("goal_id")
  title       String
  description String?
  status      String   @default("open")
  priority    String   @default("medium")
  ownerId     String?  @map("owner_id")
  createdById String   @map("created_by_id")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  company     Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  goal        Goal?         @relation(fields: [goalId], references: [id])
  owner       OrgNode?      @relation(fields: [ownerId], references: [id])
  createdBy   User          @relation(fields: [createdById], references: [id])
  events      TicketEvent[]

  @@map("tickets")
}

model TicketEvent {
  id          String   @id @default(uuid())
  ticketId    String   @map("ticket_id")
  type        String
  data        Json
  createdById String?  @map("created_by_id")
  createdAt   DateTime @default(now()) @map("created_at")

  ticket      Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@map("ticket_events")
}

model Budget {
  id            String   @id @default(uuid())
  companyId     String   @map("company_id")
  entityType    String   @map("entity_type")
  entityId      String   @map("entity_id")
  monthlyLimit  Decimal? @map("monthly_limit") @db.Decimal(12, 2)
  spentMonthly  Decimal  @default(0) @map("spent_monthly") @db.Decimal(12, 2)
  spentTotal    Decimal  @default(0) @map("spent_total") @db.Decimal(12, 2)
  alertThreshold Int     @default(80) @map("alert_threshold")
  pausedAt      DateTime? @map("paused_at")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  company       Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  orgNode       OrgNode? @relation(fields: [entityId], references: [id])

  @@map("budgets")
}

model Heartbeat {
  id          String   @id @default(uuid())
  companyId   String   @map("company_id")
  agentId     String   @map("agent_id")
  name        String?
  schedule    String
  enabled     Boolean  @default(true)
  lastRunAt   DateTime? @map("last_run_at")
  nextRunAt   DateTime? @map("next_run_at")
  runCount    Int      @default(0) @map("run_count")
  failCount   Int      @default(0) @map("fail_count")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@map("heartbeats")
}

model Approval {
  id          String   @id @default(uuid())
  companyId   String   @map("company_id")
  type        String
  title       String
  description String?
  requesterId String   @map("requester_id")
  data        Json     @default("{}")
  status      String   @default("pending")
  approverId  String?  @map("approver_id")
  decidedAt   DateTime? @map("decided_at")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  requester   OrgNode  @relation(fields: [requesterId], references: [id])
  approver    User?    @relation("ApprovedBy", fields: [approverId], references: [id])

  @@map("approvals")
}

model AuditLog {
  id          String   @id @default(uuid())
  companyId   String   @map("company_id")
  entityType  String   @map("entity_type")
  entityId    String   @map("entity_id")
  action      String
  actorId     String   @map("actor_id")
  data        Json     @default("{}")
  createdAt   DateTime @default(now()) @map("created_at")

  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@map("audit_logs")
}

model Skill {
  id          String   @id @default(uuid())
  companyId   String   @map("company_id")
  name        String
  source      String?
  sourceUrl   String?  @map("source_url")
  content     String?
  enabled     Boolean  @default(true)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@map("skills")
}

model ApiKey {
  id            String   @id @default(uuid())
  companyId     String   @map("company_id")
  provider      String
  name          String?
  keyEncrypted  String   @map("key_encrypted")
  isDefault     Boolean  @default(false) @map("is_default")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  company       Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@map("api_keys")
}
